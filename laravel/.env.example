APP_NAME="1000 A.D."
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

# SQLite for development (default)
DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/to/database.sqlite

# MySQL (optional)
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=1000ad
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@1000ad.net"
MAIL_FROM_NAME="1000 A.D."

# ============================================
# Docker / Production settings
# ============================================
# When running in Docker, these are set via
# docker-compose.yml environment variables.
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=http://your-server-ip:8080
# LOG_CHANNEL=stderr
